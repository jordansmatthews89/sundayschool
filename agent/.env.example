# Copy this file to .env and fill in your keys. Never commit .env.
# OPENAI_API_KEY is required. The rest are optional.

OPENAI_API_KEY=

# Optional: create beehiiv draft when running with --draft
# BEEHIIV_API_KEY=

# Optional: post generated tweet to X
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=

# Optional: weekly summary to Discord
# DISCORD_WEBHOOK_URL=

# Optional: Gumroad sales in summary
# GUMROAD_TOKEN=
